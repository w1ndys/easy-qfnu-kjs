# QFNU CAS 登录配置
# 复制此文件为 .env 并填写真实信息
#
# Docker Compose 部署步骤：
# 1. cp .env.example .env
# 2. 填写真实的学号、密码和管理员信息
# 3. docker compose up -d --build

# ---- 敏感信息（必须配置） ----

# QFNU 教务系统账号
QFNU_USERNAME=你的学号
QFNU_PASSWORD=你的密码

# 管理后台账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置一个强密码

# JWT 签名密钥（建议使用 32 位以上随机字符串，留空则每次重启自动生成）
JWT_SECRET=
